# Copie para .env (não versionar). DOTENV_PATH pode apontar para outro arquivo.

# ── Modo de operação ─────────────────────────────────────────────────────────
# Cada variável controla sua base independentemente:
#   SIMDNIT_UPDATE_MODE → qual banco SIMDNIT ler  (local | homolog | production)
#   SUPRA_UPDATE_MODE   → qual banco SUPRA gravar (local | homolog | production)
#
# Exemplo: ler de produção e gravar em homolog para testar:
#   SIMDNIT_UPDATE_MODE=production
#   SUPRA_UPDATE_MODE=homolog

SIMDNIT_UPDATE_MODE=local
SUPRA_UPDATE_MODE=local

# Driver ODBC (opcional — tenta 18 / 17 / 13 automaticamente)
# DRIVER=ODBC Driver 18 for SQL Server

# Escopo SIMDNIT — só contratos com este SG_UND_GESTORA em Dados_Contrato
SIMDNIT_SCOPE_SG_UND_GESTORA=CGCONT


# ── LOCAL ────────────────────────────────────────────────────────────────────

SIMDNIT_LOCAL_HOST=localhost
SIMDNIT_LOCAL_PORT=1433
SIMDNIT_LOCAL_USER=sa
SIMDNIT_LOCAL_PASS=
SIMDNIT_LOCAL_DATABASE=SIMDNIT

SUPRA_LOCAL_HOST=localhost
SUPRA_LOCAL_PORT=1433
SUPRA_LOCAL_USER=sa
SUPRA_LOCAL_PASS=
SUPRA_LOCAL_DATABASE=SUPRA


# ── HOMOLOG ──────────────────────────────────────────────────────────────────

SIMDNIT_HOM_HOST=
SIMDNIT_HOM_PORT=1433
SIMDNIT_HOM_USER=
SIMDNIT_HOM_PASS=
SIMDNIT_HOM_DATABASE=SIMDNIT

SUPRA_HOM_HOST=
SUPRA_HOM_PORT=1433
SUPRA_HOM_USER=
SUPRA_HOM_PASS=
SUPRA_HOM_DATABASE=SUPRA


# ── PRODUCTION ───────────────────────────────────────────────────────────────

SIMDNIT_PROD_HOST=
SIMDNIT_PROD_PORT=1433
SIMDNIT_PROD_USER=
SIMDNIT_PROD_PASS=
SIMDNIT_PROD_DATABASE=SIMDNIT

SUPRA_PROD_HOST=
SUPRA_PROD_PORT=1433
SUPRA_PROD_USER=
SUPRA_PROD_PASS=
SUPRA_PROD_DATABASE=SUPRA
